# ── Crawler ────────────────────────────────────────────────────────────────
# How many list pages to crawl (30 entries/page).  Set low (e.g. 3) for a
# quick test run.
MAX_PAGES=5

# Step1 page-level concurrency window size.
PAGE_CONCURRENCY=4

# Only fetch entries modified after this date (incremental mode).
# SINCE=2024-01-01

# Output directory for raw JSON, enriched YAML, and cloned repos.
DATA_DIR=./output/aliyun_cve

# GitHub personal-access token – avoids rate limits when resolving patch URLs.
# GITHUB_TOKEN=ghp_...

# ── LLM ────────────────────────────────────────────────────────────────────
LLM__PROVIDER=openai
LLM__MODEL=deepseek-v3.2
LLM__API_KEY=sk-...
# Point at a compatible proxy / local model if needed:
# LLM__BASE_URL=https://your-proxy/v1

# ── Git clone ───────────────────────────────────────────────────────────────
# Use SSH instead of HTTPS (requires a loaded SSH key):
# GIT_CLONE_VIA_SSH=false

# Forward git operations through an HTTP/SOCKS proxy:
# GIT_PROXY=socks5://127.0.0.1:1080

# ── Calltrace tuning ────────────────────────────────────────────────────────
# Parallel CVEs processed at once:
# CALLTRACE_CONCURRENCY=5
# Max LLM turns per CVE (1 initial diff + up to N-1 file-request rounds):
# CALLTRACE_MAX_ROUNDS=4

# ── Logging ────────────────────────────────────────────────────────────────
# Directory for timestamped log files. Leave commented for console-only.
# LOG_DIR=./logs
